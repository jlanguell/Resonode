# Resonode — environment configuration.
# Copy this file to ".env" and fill in your values.

# Required: your Discord bot token from the Developer Portal.
DISCORD_TOKEN=put-your-bot-token-here

# (Legacy) Command prefix — unused now that Resonode uses slash commands.
COMMAND_PREFIX=!

# --- Speech-to-text --------------------------------------------------------
# Engine: "local" (faster-whisper: private, free) or "deepgram" (cloud, paid).
RESONODE_STT=local
# Local Whisper model: tiny | base | small | medium | large-v3
WHISPER_MODEL=base
# "cpu" (default, works everywhere) or "cuda" for an NVIDIA GPU.
WHISPER_DEVICE=cpu
# Only needed if RESONODE_STT=deepgram
# DEEPGRAM_API_KEY=

# --- LLM (summaries, translation, moderation, ask) -------------------------
# Provider: "none" (default), "openai", or "anthropic". Bring your own key.
RESONODE_LLM=none
# RESONODE_LLM_MODEL=
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=

# --- Memory ("server brain") -----------------------------------------------
# "keyword" recall works out of the box; vector RAG is on the roadmap.
RESONODE_MEMORY=keyword

# --- Feature flags ---------------------------------------------------------
# Near-real-time streaming transcription (prototype; off by default).
RESONODE_STREAMING=false
# Auto-post a summary after each session (needs an LLM configured).
RESONODE_AUTO_SUMMARY=false

# --- Testing ---------------------------------------------------------------
# Optional: a server (guild) ID where slash commands register instantly.
# Leave blank for global commands (which can take up to ~1 hour to appear).
RESONODE_DEV_GUILD=
